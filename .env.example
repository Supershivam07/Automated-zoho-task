# ============================================================
# .env.example — Copy this to .env and fill in your values
# NEVER commit your real .env to Git!
# ============================================================

# --- ZOHO OAUTH CREDENTIALS ---
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token_here
ZOHO_REDIRECT_URI=http://localhost:8000/callback

# --- ZOHO PORTAL & PROJECT ---
ZOHO_PORTAL_ID=your_portal_id_here
ZOHO_PROJECT_ID=your_project_id_here

# --- GOOGLE SHEETS ---
# Place your Google Service Account credentials.json in the project root
# (do NOT commit credentials.json to Git)

# --- EMAIL (SMTP via Gmail App Password) ---
SMTP_SENDER_EMAIL=your_gmail_address@gmail.com
SMTP_SENDER_PASSWORD=your_gmail_app_password_here
